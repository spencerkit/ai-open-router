{
  "_doc": "Proxy-chain benchmark config: load-test via local proxy endpoint (/oc/:groupId/*), not direct upstream.",
  "_docAuth": "If server.authEnabled=false, delete headers.authorization.",
  "_docNonStreamMode": "nonStream.mode: fixed_requests | duration; duration gives more stable curves.",
  "_docWarmup": "warmupSec is preheat traffic before each non-stream matrix point and is excluded from metrics.",
  "_docThresholds": "thresholds control health grade (green/yellow/red) by success rate, timeout count and p95.",
  "warmupSec": 3,
  "baseUrl": "http://localhost:8999",
  "path": "/oc/mock-group/responses",
  "method": "POST",
  "headers": {
    "authorization": "Bearer __LOCAL_BEARER_TOKEN_IF_AUTH_ENABLED__"
  },
  "expectStatus": [200],
  "requestTimeoutMs": 65000,
  "streamTimeoutMs": 600000,
  "thresholds": {
    "nonStream": {
      "minSuccessRatePct": 99.9,
      "maxTimeoutCount": 0,
      "p95WarnMs": 250,
      "p95FailMs": 800
    },
    "stream": {
      "minSuccessRatePct": 99.9,
      "maxTimeoutCount": 0,
      "p95WarnMs": 1000,
      "p95FailMs": 3000
    },
    "mixed": {
      "nonStream": {
        "minSuccessRatePct": 99.9,
        "maxTimeoutCount": 0,
        "p95WarnMs": 300,
        "p95FailMs": 1000
      },
      "stream": {
        "minSuccessRatePct": 99.9,
        "maxTimeoutCount": 0,
        "p95WarnMs": 1200,
        "p95FailMs": 3500
      }
    }
  },
  "nonStream": {
    "enabled": true,
    "mode": "duration",
    "durationSec": 15,
    "warmupSec": 3,
    "concurrency": [1, 8, 32, 128],
    "totalRequests": 400,
    "path": "/oc/mock-group/responses",
    "body": {
      "model": "mock-model",
      "input": "ping"
    }
  },
  "stream": {
    "enabled": true,
    "concurrency": [10, 50, 100],
    "durationSec": 30,
    "path": "/oc/mock-group/responses",
    "body": {
      "model": "mock-model",
      "input": "stream test",
      "stream": true
    }
  },
  "mixed": {
    "enabled": true,
    "durationSec": 30,
    "nonStreamConcurrency": 32,
    "streamConcurrency": 20,
    "nonStreamPath": "/oc/mock-group/responses",
    "streamPath": "/oc/mock-group/responses",
    "nonStreamBody": {
      "model": "mock-model",
      "input": "mixed non-stream"
    },
    "streamBody": {
      "model": "mock-model",
      "input": "mixed stream",
      "stream": true
    }
  }
}
